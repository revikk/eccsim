{minimum_otp_vsn, "27"}.

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_export_vars,
    warn_unused_import,
    warn_missing_spec
]}.

{deps, [
    {etiq, {git, "https://github.com/revikk/etiq.git", {branch, "main"}}},
    {eqwalizer_support,
        {git_subdir,
            "https://github.com/whatsapp/eqwalizer.git",
            {branch, "main"},
            "eqwalizer_support"}}
]}.

{project_plugins, [
    {rebar3_lint, "4.2.1"}
]}.

{shell, [
    {apps, [eccsim]}
]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all, nowarn_missing_spec]},
        {ct_opts, [{verbose, true}]},
        {cover_enabled, true}
    ]}
]}.

{escript_main_app, eccsim}.
{escript_name, eccsim}.
{escript_emu_args, "%%! -escript main eccsim_cli +sbtu +A1\n"}.
{escript_incl_apps, [etiq]}.

{elvis_output_format, colors}.

%% eccsim_cli:main/1 is the escript entry point (called by escript runtime).
%% eccsim_sim:start_link/1 is called dynamically by supervisor:start_child via child spec.
{xref_ignores, [
    {eccsim_cli, main, 1},          % escript runtime entry point
    {eccsim_cli, do_run, 1},        % exported for testing
    {eccsim_cli, print_results, 1}, % exported for testing
    {eccsim_sim, start_link, 1}     % called via supervisor child spec
]}.
